# Copy to .env and fill in values you actually need.
# Most APIs used here (Nominatim, BFS, Swisstopo, OSM) are key-free.

# Nominatim requires a contact identifier in the User-Agent per their usage policy.
NOMINATIM_USER_AGENT=retail-site-intelligence (contact: t.strathaus@mail.ch)

# Optional: Google Maps key for richer POI / Popular Times. Not required.
GOOGLE_MAPS_API_KEY=

# Optional: Strava Global Heatmap tile URL.
# Strava's heatmap tiles require an authenticated session — they cannot be
# used anonymously. If you want a real Strava overlay on the maps:
#   1. Log into strava.com/maps/global-heatmap
#   2. Open DevTools → Network → click a tile request
#   3. Copy the full URL (contains Key-Pair-Id / Policy / Signature query params)
#   4. Replace {z}/{x}/{y} with {z}/{x}/{y} placeholders so folium can substitute
#   5. Set the URL here. Expires every ~2 weeks per Strava's CDN policy.
# When empty, the tool falls back to OSM running infrastructure (parks +
# running routes + cycleways) — fully public, no auth required.
STRAVA_TILE_URL=
