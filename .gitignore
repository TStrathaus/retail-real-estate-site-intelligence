# --- secrets ---
.env
.streamlit/secrets.toml

# --- python ---
__pycache__/
*.pyc
.venv/
venv/
.ipynb_checkpoints/

# --- generated / cached (regenerable, large) ---
data/cache/
data/db/*.db
streamlit_*.log
*.log

# Office lock files
~$*

# Generated artefacts — regenerate via sample_run.py / tools/
outputs/

# --- third-party reference material (copyright — do NOT publish) ---
research/

# --- local-only working notes (kept on disk, not published) ---
